root = true

[*]
indent_style = space
indent_size = 2
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf
max_line_length = off

[*.{yml,yaml,ts,cts,mts,js,cjs,mjs}]
indent_size = 2

[package.json]
indent_size = 2

[{CHANGELOG.md,yarn.lock}]
indent_size = false
