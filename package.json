{
  "name": "@monoweave/monorepo",
  "version": "1.0.0",
  "type": "module",
  "description": "A small wrapper around yarn berry that makes it easier to use in CI",
  "repository": {
    "type": "git",
    "url": "https://github.com/monoweave/monoweave.git"
  },
  "author": {
    "name": "noahnu",
    "url": "https://monoweave.github.io/monoweave/"
  },
  "license": "BSD-3",
  "private": true,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "workspaces": [
    "packages/*",
    "testUtils",
    "e2e-tests",
    "docs-site"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf ${ARTIFACT_DIR:-artifacts} .tmp && yarn workspaces foreach -vpi --worktree run clean",
    "build": "yarn workspaces foreach -vpi --worktree --topological-dev run prepack",
    "contrib:add": "all-contributors add",
    "contrib:check": "all-contributors check",
    "contrib:generate": "all-contributors generate",
    "format:ci": "oxfmt --check",
    "lint:ci": "oxlint --format=github",
    "lint": "oxfmt && oxlint --fix",
    "bin:vitest:debug": "yarn node --inspect-brk $(yarn bin vitest) --config=vitest.config.ts",
    "bin:vitest": "yarn node $(yarn bin vitest) --config=vitest.config.ts",
    "test:ci": "CI=1 yarn bin:vitest --project=\"Unit/Integration\" --",
    "test:watch": "yarn bin:vitest --project=\"Unit/Integration\" --",
    "test": "yarn bin:vitest --project=\"Unit/Integration\" --",
    "test:all": "yarn test:ci && yarn test:e2e && yarn test:coverage:merge && yarn test:coverage:report",
    "test:e2e": "E2E=1 yarn workspace @monoweave/e2e-tests run test",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "typecheck:watch": "run typecheck --pretty --watch",
    "workspace:build:watch": "tsc -p $0/tsconfig.build.json --watch",
    "workspace:build": "rm -rf $0/lib $0/.tmp && tsc -p $0/tsconfig.build.json",
    "workspace:clean": "rm -rf $0/lib $0/.tmp && find $0/src -name '*.js' -type f -delete",
    "workspace:test:watch": "run workspace:test --watch",
    "workspace:test": "yarn bin:vitest",
    "workspace:types:watch": "tsc -p $0 --noEmit --emitDeclarationOnly false --pretty --watch",
    "run-local": "tsx $(yarn bin monoweave)",
    "docs": "yarn workspace @monoweave/docs-site build",
    "docs:dev": "yarn workspace @monoweave/docs-site start",
    ":e2e": "yarn workspace @monoweave/e2e-tests",
    "update:yarn": "corepack use yarn@^4 && yarn && yarn up \"@yarnpkg/*\" && yarn constraints --fix && yarn dedupe"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@monoweave/cli": "workspace:*",
    "@monoweave/git": "workspace:*",
    "@monoweave/io": "workspace:*",
    "@monoweave/logging": "workspace:*",
    "@monoweave/plugin-github": "workspace:*",
    "@monoweave/test-utils": "workspace:*",
    "@monoweave/types": "workspace:*",
    "@noahnu/yarn-semver-up": "^0.0.6",
    "@tophat/commitlint-config": "^1.0.2",
    "@tophat/conventional-changelog-config": "^1.0.1",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.8",
    "@yarnpkg/cli": "^4.16.0",
    "@yarnpkg/core": "^4.8.0",
    "@yarnpkg/fslib": "^3.1.5",
    "@yarnpkg/plugin-npm": "^3.6.0",
    "@yarnpkg/plugin-pack": "^4.0.4",
    "@yarnpkg/sdks": "^3.3.0",
    "@yarnpkg/shell": "^4.1.3",
    "@yarnpkg/types": "^4.0.1",
    "all-contributors-cli": "^6.26.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "yaml-validator": "^5.1.0"
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
